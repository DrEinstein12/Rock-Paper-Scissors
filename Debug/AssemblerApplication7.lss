                                 ;***********************************************************
                                 ;*  Additional Program Includes
                                 ;***********************************************************
                                 .include "LCDDriver.asm"		; Include the LCD Driver
                                 
                                 ;*	Oregon State University
                                 ;*	ST7565R LCD Driver
                                 ;*	This code configures the graphical LCD and emulates
                                 ;*	the behavior of a 2x16 character display.
                                 ;*
                                 ;*	The LCD has room for 32 characters in total
                                 ;*	(16 on the top and 16 on the bottom).
                                 ;*	The upper 16 characters should be located in SRAM starting at 0x0100.
                                 ;*	The lower 16 characters should be located in SRAM starting at 0x0110.
                                 ;*
                                 ;*	NOTE: Register r16 MUST be named 'mpr' in the Main Code
                                 ;*	Something like this:
                                 ;*	.def	mpr = r16
                                 ;*
                                 ;*	WARNING: Register r20-r22 are reserved and cannot be
                                 ;*		renamed outside of the LCD Driver functions. Doing
                                 ;*		so will damage the functionality of the LCD Driver
                                 ;*
                                 ;*	Acknowledgements: the Bin2ASCII and div10 procedures were written by
                                 ;*	David Zier for a previous board. The code has been retained intact.
                                 ;*
                                 ;*********************************************************************
                                 ;*	Rev	Date		Name			Description
                                 ;*--------------------------------------------------------------------
                                 ;*	-	8/18/22	Justin Goins	Version 1.0
                                 ;*
                                 ;*
                                 ;*********************************************************************
                                 
                                 .include "m32U4def.inc"				; Include definition file
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega32U4.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m32U4def.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega32U4
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega32U4
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M32U4DEF_INC_
                                 #endif  /* _M32U4DEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; Register definitions
                                 .def	count = r20			; Character Counter
                                 .def	q = r21			; Quotient for div10
                                 .def	r = r22			; Remander for div10
                                 
                                 ; The following constants are not intended to be modified.
                                 .equ	lcd_buffer_addr = 0x0100 ; define the SRAM base address of the LCD buffer
                                 
                                 ; This information is gathered from the ST7565R datasheet.
                                 ; define some command patterns
                                 .equ	lcd_c_disp_en = 0b10101110 ; lsb indicates whether the LCD is on (1) or off (0)
                                 .equ	lcd_c_disp_set_start_ln = 0b01000000 ; lower 6 bits indicate the line index (0 - 63)
                                 .equ	lcd_c_disp_set_page_addr = 0b10110000 ; lower 4 bits indicate the page address (page 3 is at top and page 0 is at bottom)
                                 ; together, these commands allow you to specify a column index from (0 - 131):
                                 .equ	lcd_c_disp_set_col_addr_h = 0b00010000 ; lower 4 bits indicate the 4 high bits of the column address
                                 .equ	lcd_c_disp_set_col_addr_l = 0b00000000 ; lower 4 bits indicate the 4 low bits of the column address
                                 .equ	lcd_c_disp_set_invert = 0b10100110 ; lsb indicates whether the LCD is normal (0) or inverted (1)
                                 .equ	lcd_c_disp_fill = 0b10100100 ; lsb indicates whether the LCD is normal (0) or filled with dots (1)
                                 .equ	lcd_c_disp_reset = 0b11100010 ; resets the line/page addresses and other stuff, does not affect data RAM
                                 .equ	lcd_c_disp_set_bias = 0xA2 ; 1/6 bias (in 1/33 duty mode)
                                 .equ	lcd_c_disp_set_scandir = 0b11000000 ; select normal scan direction (most significant bit is placed at top of LCD)
                                 .equ	lcd_c_disp_set_contrast_1 = 0b10000001 ; first we send this command then we pass the value
                                 .equ	lcd_c_disp_set_contrast_2 = 15 ; can select a contrast value between 1 and 63
                                 .equ	lcd_c_disp_set_res_ratio = 0x22 ; see the datasheet
                                 .equ	lcd_c_disp_vreg_on = 0x2F ; enable voltage booster, voltage regulator, and voltage follower
                                 
                                 ; use this command to write into the LCD RAM:
                                 .equ	lcd_c_disp_write = 0b00000000 ; these 8 bits are the data to be placed in the target. 
                                 ; note that the column address is automatically incremented by 1 after each write to the LCD data
                                 
                                 ; everything in this driver file needs to go into the code segment
                                 .cseg
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDInit
                                 ;* Desc:	This function initializes the LCD control pins and
                                 ;*		sets reasonable values for the configuration registers.
                                 ;*****************************************************************
                                 LCDInit:
00020a 930f                      	push	mpr
                                 
                                 	; set MOSI, SCL, and SS as outputs
00020b 9a22                      	sbi	DDRB, DDB2	; Port B 2
00020c 9a21                      	sbi	DDRB, DDB1	; Port B 1
00020d 9a20                      	sbi	DDRB, DDB0	; Port B 0
                                 	; ensure that SS is deactivated (active low)
00020e 9a28                      	sbi	PORTB, 0
                                 	; set lcd_A0 as output
00020f 9a81                      	sbi	DDRF, DDF1	; Port F 1
                                 	; enable LCD backlight control
000210 9a3f                      	sbi	DDRC, DDC7	; Port C 7
                                 	; set lcd_RST_N as output
000211 9a80                      	sbi	DDRF, DDF0	; Port F 0
                                 	; we pull lcd_RST_N low for 1 millisecond
000212 9888                      	cbi	PORTF, 0
000213 940e 02f5                 	call	LCDDelay
000215 9a88                      	sbi	PORTF, 0
                                 	; Enable SPI mode 3, master configuration, set clock rate fck/2 using SPI2X
000216 e50c                      	ldi	mpr, (1<<SPE)|(1<<MSTR)|(1<<CPOL)|(1<<CPHA)
000217 bd0c                      	out	SPCR, mpr
000218 e001                      	ldi	mpr, (1<<SPI2X)
000219 bd0d                      	out	SPSR, mpr
                                 	; Note: after transmitting a byte, the SPI interrupt flag will
                                 	; be automatically cleared next time we: 1) read SPSR and ALSO 2) access SPDR
                                 
00021a 9828                      	cbi	PORTB, 0	; activate slave select
                                 	; send a string of initialization commands
00021b ea02                      	ldi	mpr, lcd_c_disp_set_bias
00021c d0d2                      	rcall	LCD_Internal_WriteCMD
00021d ec00                      	ldi	mpr, lcd_c_disp_set_scandir
00021e d0d0                      	rcall	LCD_Internal_WriteCMD
00021f e801                      	ldi	mpr, lcd_c_disp_set_contrast_1
000220 d0ce                      	rcall	LCD_Internal_WriteCMD
000221 e00f                      	ldi	mpr, lcd_c_disp_set_contrast_2
000222 d0cc                      	rcall	LCD_Internal_WriteCMD
000223 e202                      	ldi	mpr, lcd_c_disp_set_res_ratio
000224 d0ca                      	rcall	LCD_Internal_WriteCMD
000225 e20f                      	ldi	mpr, lcd_c_disp_vreg_on
000226 d0c8                      	rcall	LCD_Internal_WriteCMD
000227 ea0f                      	ldi	mpr, (lcd_c_disp_en | 1 << 0)
000228 d0c6                      	rcall	LCD_Internal_WriteCMD
000229 9a28                      	sbi	PORTB, 0	; deactivate slave select
                                 
00022a 910f                      	pop	mpr
00022b 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDBacklightOn
                                 ;* Desc:	Enables the backlight
                                 ;*****************************************************************
                                 LCDBacklightOn:
00022c 9a47                      	sbi	PORTC, 7
00022d 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDBacklightOff
                                 ;* Desc:	Disables the backlight
                                 ;*****************************************************************
                                 LCDBacklightOff:
00022e 9847                      	cbi	PORTC, 7
00022f 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDWrite
                                 ;* Desc:	This function writes 32 characters to the LCD screen...
                                 ;*		16 chars on the top line and 16 chars on the bottom line.
                                 ;*****************************************************************
                                 LCDWrite:
000230 d002                      	rcall	LCDWrLn1
000231 d00c                      	rcall	LCDWrLn2
000232 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDWrLn1
                                 ;* Desc:	This function writes 16 characters to the top line.
                                 ;*****************************************************************
                                 LCDWrLn1:
000233 93bf                      	push	XH
000234 93af                      	push	XL
000235 931f                      	push	r17
                                 	; r17 specifies the destination bank in LCD RAM
000236 e013                      	ldi	r17, 3
                                 	; point X at the ASCII data
000237 e0b1                      	ldi	XH, HIGH(lcd_buffer_addr)
000238 e0a0                      	ldi	XL, LOW(lcd_buffer_addr)
000239 d05c                      	rcall	LCD_Internal_WriteLn
00023a 911f                      	pop	r17
00023b 91af                      	pop	XL
00023c 91bf                      	pop	XH
00023d 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDWrLn2
                                 ;* Desc:	This function writes 16 characters to the bottom line.
                                 ;*****************************************************************
                                 LCDWrLn2:
00023e 93bf                      	push	XH
00023f 93af                      	push	XL
000240 931f                      	push	r17
                                 	; r17 specifies the destination bank in LCD RAM
000241 e011                      	ldi	r17, 1
                                 	; point X at the ASCII data
000242 e0b1                      	ldi	XH, HIGH(lcd_buffer_addr+16)
000243 e1a0                      	ldi	XL, LOW(lcd_buffer_addr+16)
000244 d051                      	rcall	LCD_Internal_WriteLn
000245 911f                      	pop	r17
000246 91af                      	pop	XL
000247 91bf                      	pop	XH
000248 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDClr
                                 ;* Desc:	This function clears the entire LCD screen.
                                 ;*****************************************************************
                                 LCDClr:
000249 d022                      	rcall	LCDClrLn1
00024a d027                      	rcall	LCDClrLn2
                                 
00024b 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	CLRDM1
                                 ;* Desc:	This function clears Data Memory by writing 16 
                                 ;*		consecutive ASCII spaces $20 to the memory at $0100.
                                 ;*****************************************************************
                                 CLRDM1:
                                     ; Set X register points to $0100
00024c 93bf                      	   push	   XH
00024d 93af                      	   PUSH	   XL
00024e 930f                                 push    r16
00024f 931f                                 push    r17
                                 
000250 e0b1                                 ldi     XH, HIGH(lcd_buffer_addr)
000251 e0a0                                 ldi     XL, LOW(lcd_buffer_addr)
000252 e110                                 ldi     r17, 16
000253 e200                                 ldi     r16, ' '
                                    CLRloop1:
000254 930d                                 st      X+, r16         ; load data to DM
000255 951a                                 dec     r17
000256 f7e9                                 brne    CLRloop1
                                 
000257 911f                      	   pop	   r17
000258 910f                      	   pop	   r16
000259 91af                      	   pop	   XL
00025a 91bf                      	   pop	   XH
                                 
00025b 9508                                 ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	CLRDM2
                                 ;* Desc:	This function clears Data Memory by writing 16 
                                 ;*		consecutive ASCII spaces $20 to the memory at $0110.
                                 ;*****************************************************************
                                 CLRDM2:
                                     ; Set X register points to $0110
00025c 93bf                      	   push	   XH
00025d 93af                      	   PUSH	   XL
00025e 930f                                 push    r16
00025f 931f                                 push    r17
                                 
000260 e0b1                                 ldi     XH, HIGH(lcd_buffer_addr+16)
000261 e1a0                                 ldi     XL, LOW(lcd_buffer_addr+16)
000262 e110                                 ldi     r17, 16
000263 e200                                 ldi     r16, ' '
                                    CLRloop2:
000264 930d                                 st      X+, r16         ; load data to DM
000265 951a                                 dec     r17
000266 f7e9                                 brne    CLRloop2
                                 
000267 911f                      	   pop	   r17
000268 910f                      	   pop	   r16
000269 91af                      	   pop	   XL
00026a 91bf                      	   pop	   XH
                                 
00026b 9508                                 ret
                                 ;*****************************************************************
                                 ;* Func:	LCDClrLn1
                                 ;* Desc:	This function clears the top line of the LCD screen.
                                 ;*****************************************************************
                                 LCDClrLn1:
00026c 931f                      	push	r17
                                 	; r17 specifies the target bank in LCD RAM
00026d e013                      	ldi	r17, 3
00026e d060                      	rcall	LCD_Internal_ClearLn
00026f dfdc                      	rcall	CLRDM1
000270 911f                      	pop	r17
000271 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDClrLn2
                                 ;* Desc:	This function clears the bottom line of the LCD screen.
                                 ;*****************************************************************
                                 LCDClrLn2:
000272 931f                      	push	r17
                                 	; r17 specifies the target bank in LCD RAM
000273 e011                      	ldi	r17, 1
000274 d05a                      	rcall	LCD_Internal_ClearLn
000275 dfe6                      	rcall	CLRDM2
000276 911f                      	pop	r17
000277 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	Bin2ASCII
                                 ;* Desc:	Converts a binary number into an ASCII 
                                 ;*			text string equivalent. 
                                 ;*			- The binary number needs to be in the mpr
                                 ;*			- The Start Address of where the text will
                                 ;*			 	be placed needs to be in the X Register
                                 ;*			- The count of the characters created are 
                                 ;*				added to the count register
                                 ;*****************************************************************
                                 Bin2ASCII:
000278 930f                      	push	mpr			; save mpr
000279 936f                      	push	r			; save r
00027a 935f                      	push	q			; save q
00027b 93bf                      	push	XH			; save X-pointer
00027c 93af                      	push	XL			;
                                 
                                 	; Determine the range of mpr
00027d 3604                      	cpi	mpr, 100		; is mpr >= 100
00027e f018                      	brlo	B2A_1			; goto next check
00027f e043                      	ldi	count, 3		; Three chars are written
000280 9613                      	adiw	XL, 3			; Increment X 3 address spaces
000281 c007                      	rjmp	B2A_3			; Continue with program
                                 B2A_1:
000282 300a                      	cpi	mpr, 10		; is mpr >= 10
000283 f018                      	brlo	B2A_2			; Continue with program
000284 e042                      	ldi	count, 2		; Two chars are written
000285 9612                      	adiw	XL, 2			; Increment X 2 address spaces
000286 c002                      	rjmp	B2A_3			; Continue with program
                                 B2A_2:
000287 9611                      	adiw	XL, 1			; Increment X 1 address space
000288 e041                      	ldi	count, 1		; One char is written
                                 
                                 B2A_3:
                                 	; Do-While statement that converts Binary to ASCII
000289 d076                      	rcall	div10			; Call the div10 function
00028a e300                      	ldi	mpr, '0'		; Set the base ASCII integer value
00028b 0f06                      	add	mpr, r		; Create the ASCII integer value
00028c 930e                      	st	-X, mpr		; Load ASCII value to memory
00028d 2f05                      	mov	mpr, q		; Set mpr to quotient value
00028e 3000                      	cpi	mpr, 0		; does mpr == 0
00028f f7c9                      	brne	B2A_3			; do while (mpr != 0)
                                 
000290 91af                      	pop	XL			; restore X-pointer
000291 91bf                      	pop	XH			;
000292 915f                      	pop	q			; restore q
000293 916f                      	pop	r			; restore r
000294 910f                      	pop	mpr			; restore mpr
000295 9508                      	ret				; return from function
                                 
                                 ;*****************************************************************
                                 ;*	The functions below here are intended for internal use only.
                                 ;*****************************************************************
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCD_Internal_WriteLn
                                 ;* Desc:	Sends 16 characters of information to the LCD panel
                                 ;*		This is slightly more complicated than it sounds because the
                                 ;*		characters straddle two banks of the LCD memory.
                                 ;*		X is pointing at the first ASCII character to be displayed.
                                 ;*		r17 holds the index of the destination bank in LCD RAM.
                                 ;*		
                                 ;*****************************************************************
                                 LCD_Internal_WriteLn:
000296 920f                      	push	r0
000297 921f                      	push	r1
000298 930f                      	push	mpr
000299 932f                      	push	r18
00029a 933f                      	push	r19
00029b 938f                      	push	r24
00029c 939f                      	push	r25
00029d 93ef                      	push	ZL
00029e 93ff                      	push	ZH
                                 
                                 	; r25:24 holds a pointer to the base address of the bitmap array
00029f e096                      	ldi	r25, HIGH(FontBitmap << 1);
0002a0 e48c                      	ldi	r24, LOW(FontBitmap << 1);
                                 
0002a1 9828                      	cbi	PORTB, 0	; activate slave select
                                 
                                 	; use a counter to track if we are on the top chunk or bottom chunk of each char
0002a2 e022                      	ldi	r18, 2
                                 
                                 LCD_WL_display_bank:
                                 	; set the column to 0
0002a3 e100                      	ldi	mpr, lcd_c_disp_set_col_addr_h
0002a4 d04a                      	rcall	LCD_Internal_WriteCMD
0002a5 e000                      	ldi	mpr, lcd_c_disp_set_col_addr_l
0002a6 d048                      	rcall	LCD_Internal_WriteCMD
                                 	; we need to select the appropriate page
0002a7 eb00                      	ldi	mpr, lcd_c_disp_set_page_addr
0002a8 2b01                      	or	mpr, r17	; set the lower 4 bits
0002a9 d045                      	rcall	LCD_Internal_WriteCMD
                                 
0002aa e130                      	ldi	r19, 16	; there are 16 characters per line
                                 
                                 LCD_WL_next_char:
                                 	; get ascii code point & determine location of corresponding character bitmap
0002ab 900d                      	ld	r0, X+	; this should be a value from 0 to 255
0002ac e100                      	ldi	mpr, 16	; there are 16 bytes per character
0002ad 9e00                      	mul	r0, mpr	; determine the byte offset for the desired char
0002ae 01fc                      	movw	ZH:ZL, r25:r24	; copy the base address to Z
0002af 0de0                      	add	ZL, r0	; finally, compute a pointer to the char bitmap
0002b0 1df1                      	adc	ZH, r1
                                 
0002b1 e008                      	ldi	mpr, 8	; there are 8 columns for each character
                                 
                                 	; this is where we display the chunk of character (either a top chunk or bottom chunk)
0002b2 9004                      	lpm	r0, Z
                                 LCD_WL_next_col:
0002b3 bc0e                      	out	SPDR, r0
0002b4 9a89                      	sbi	PORTF, 1	; set lcd_A0 to specify data mode
0002b5 9632                      	adiw	ZH:ZL, 2	; point Z at the next column for this bank
0002b6 9004                      	lpm	r0, Z		; this is a sneaky way to save a few clock cycles (since we are waiting for the SPI communication)
                                 LCD_WL_wait_spi:
0002b7 b41d                      	in	r1, SPSR
0002b8 fe17                      	sbrs	r1, SPIF	; wait for SPI to finish
0002b9 cffd                      	rjmp	LCD_WL_wait_spi
                                 
                                 	; keep going until we have displayed all the columns for this character
0002ba 950a                      	dec	mpr
0002bb f7b9                      	brne	LCD_WL_next_col
                                 
                                 	; move to the next character
0002bc 953a                      	dec	r19
0002bd f769                      	brne	LCD_WL_next_char
                                 
                                 	; if we are at the end of the line, configure the bank and starting array offset for the bottom half of each char
0002be 952a                      	dec	r18		; did we display both banks yet?
0002bf f021                      	breq	LCD_WL_all_done
                                 	; if not, then prepare to display the bottom chunk of each character
0002c0 951a                      	dec	r17		; decrement the bank number
0002c1 9750                      	sbiw	XH:XL, 16	; X needs to point back at the beginning character of the line
0002c2 9601                      	adiw	r25:r24, 1	; increment the base address pointer (now it will point to the second chunk of each char)
0002c3 cfdf                      	rjmp	LCD_WL_display_bank
                                 
                                 LCD_WL_all_done:
0002c4 9a28                      	sbi	PORTB, 0	; deactivate slave select
                                 
0002c5 91ff                      	pop	ZH
0002c6 91ef                      	pop	ZL
0002c7 919f                      	pop	r25
0002c8 918f                      	pop	r24
0002c9 913f                      	pop	r19
0002ca 912f                      	pop	r18
0002cb 910f                      	pop	mpr
0002cc 901f                      	pop	r1
0002cd 900f                      	pop	r0
0002ce 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCD_Internal_ClearLn
                                 ;* Desc:	This function clears two of the LCD memory banks.
                                 ;*		r17 specifies the starting bank to wipe.
                                 ;*****************************************************************
                                 LCD_Internal_ClearLn:
0002cf 930f                      	push	mpr
0002d0 921f                      	push	r1
0002d1 932f                      	push	r18
0002d2 933f                      	push	r19
                                 
0002d3 9828                      	cbi	PORTB, 0	; activate slave select
0002d4 e032                      	ldi	r19, 2	; we are going to clear two banks
                                 
                                 LCD_CLRLN_clear_bank:
                                 	; set the column to 0
0002d5 e100                      	ldi	mpr, lcd_c_disp_set_col_addr_h
0002d6 d018                      	rcall	LCD_Internal_WriteCMD
0002d7 e000                      	ldi	mpr, lcd_c_disp_set_col_addr_l
0002d8 d016                      	rcall	LCD_Internal_WriteCMD
                                 	; we need to select the appropriate page
0002d9 eb00                      	ldi	mpr, lcd_c_disp_set_page_addr
0002da 2b01                      	or	mpr, r17	; configure the lower 4 bits
0002db d013                      	rcall	LCD_Internal_WriteCMD
                                 
0002dc e820                      	ldi	r18, 128	; there are 128 columns on the LCD
0002dd 2700                      	clr	mpr		; we will fill each column with empty dots (i.e. blank space)
0002de 9a89                      	sbi	PORTF, 1	; set lcd_A0 to specify data mode
                                 
                                 LCD_CLRLN_write_col:
0002df bd0e                      	out	SPDR, mpr	; send an empty column to the LCD via SPI
                                 LCD_CLRLN_wait_spi:
0002e0 b41d                      	in	r1, SPSR
0002e1 fe17                      	sbrs	r1, SPIF	; wait for SPI to finish
0002e2 cffd                      	rjmp	LCD_CLRLN_wait_spi
                                 
0002e3 952a                      	dec	r18
0002e4 f7d1                      	brne	LCD_CLRLN_write_col	; cycle through all 128 columns
                                 
                                 	; clear the remaining bank if we haven't done so already
0002e5 953a                      	dec	r19
0002e6 f011                      	breq	LCD_CLRLN_all_done
0002e7 951a                      	dec	r17		; decrement the bank index
0002e8 cfec                      	rjmp	LCD_CLRLN_clear_bank
                                 
                                 LCD_CLRLN_all_done:
0002e9 9a28                      	sbi	PORTB, 0	; deactivate slave select	
                                 	
                                 	; pop registers...
0002ea 913f                      	pop	r19
0002eb 912f                      	pop	r18
0002ec 901f                      	pop	r1
0002ed 910f                      	pop	mpr
0002ee 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCD_Internal_WriteCMD
                                 ;* Desc:	Sends the byte in mpr
                                 ;*		If you use this function directly,
                                 ;*		YOU ARE RESPONSIBLE for handling the slave select line!
                                 ;*****************************************************************
                                 LCD_Internal_WriteCMD:
0002ef bd0e                      	out	SPDR, mpr	; initiate transmission
0002f0 9889                      	cbi	PORTF, 1	; clear lcd_A0 to put the lcd into command mode
                                 				; (this just has to be done before the 8th bit
                                 				; is transmitted via SPI)
                                 LCD_IWC_L1:
0002f1 b50d                      	in	mpr, SPSR
0002f2 ff07                      	sbrs	mpr, SPIF	; wait for SPI to finish
0002f3 cffd                      	rjmp LCD_IWC_L1
0002f4 9508                      	ret
                                 
                                 ;*****************************************************************
                                 ;* Func:	LCDDelay
                                 ;* Desc:	A wait loop that will consume roughly 1ms
                                 ;*		Note that a CALL takes 4 cycles on top of this delay.
                                 ;*****************************************************************
                                 LCDDelay:
0002f5 930f                      	push	mpr		; 2 cycles
0002f6 931f                      	push	r17		; 2 cycles
0002f7 e01b                      	ldi	r17, 11	; 1 cycle
                                 LCDDelay_L1:
0002f8 ef02                      	ldi	mpr, 242	; 1 cycle
                                 LCDDelay_L2:
0002f9 950a                      	dec	mpr		; 1 cycle
0002fa f7f1                      	brne	LCDDelay_L2	; 2 cycles on branch, 1 if no branch
0002fb 951a                      	dec	r17		; 1 cycle
0002fc f7d9                      	brne	LCDDelay_L1	; 2 cycles on branch, 1 if no branch
0002fd 911f                      	pop	r17		; 2 cycles
0002fe 910f                      	pop	mpr		; 2 cycles
0002ff 9508                      	ret			; 4 cycles
                                 
                                 ;*****************************************************************
                                 ;* Func:	div10
                                 ;* Desc:	Divides the value in the mpr by 10 and 
                                 ;*			puts the remainder in the 'r' register
                                 ;*			and the quotient in the 'q' register.
                                 ;*	DO NOT modify this function, trust me, it does
                                 ;*	divide by 10 :)  ~DZ		
                                 ;*****************************************************************
                                 div10:
000300 920f                      	push	r0		; Save register
                                 
                                 	; q = mpr / 10 = mpr * 0.000110011001101b
000301 2f50                      	mov	q, mpr	; q = mpr * 1.0b
000302 9556                      	lsr	q		; q >> 2
000303 9556                      	lsr	q		; q = mpr * 0.01b
000304 0f50                      	add	q, mpr	; q = (q + mpr) >> 1
000305 9556                      	lsr	q		; q = mpr * 0.101b
000306 0f50                      	add	q, mpr	; q = (q + mpr) >> 3
000307 9556                      	lsr	q
000308 9556                      	lsr	q
000309 9556                      	lsr	q		; q = mpr * 0.001101b
00030a 0f50                      	add	q, mpr	; q = (q + mpr) >> 1
00030b 9556                      	lsr	q		; q = mpr * 0.1001101b
00030c 0f50                      	add	q, mpr	; q = (q + mpr) >> 3
00030d 9556                      	lsr	q				
00030e 9556                      	lsr	q
00030f 9556                      	lsr	q		; q = mpr * 0.0011001101b
000310 0f50                      	add	q, mpr	; q = (q + mpr) >> 1
000311 9556                      	lsr	q		; q = mpr * 0.10011001101b
000312 0f50                      	add	q, mpr	; q = (q + mpr) >> 4
000313 9556                      	lsr	q
000314 9556                      	lsr	q
000315 9556                      	lsr	q
000316 9556                      	lsr	q		; q = mpr * 0.000110011001101b
                                 
                                 	; compute the remainder as r = i - 10 * q
                                 	; calculate r = q * 10 = q * 1010b
000317 2f65                      	mov	r, q		; r = q * 1
000318 0f66                      	lsl	r		; r << 2
000319 0f66                      	lsl	r		; r = q * 100b
00031a 0f65                      	add	r, q		; r = (r + q) << 1
00031b 0f66                      	lsl	r		; r = q * 1010b
00031c 2e06                      	mov	r0, r		; r0 = 10 * q
00031d 2f60                      	mov	r, mpr	; r = mpr
00031e 1960                      	sub	r, r0		; r = mpr - 10 * q
                                 
                                 	; Fix any errors that occur
                                 div10_1:
00031f 306a                      	cpi	r, 10		; Compare with 10
000320 f018                      	brlo	div10_2	; do nothing if r < 10
000321 9553                      	inc	q		; fix quotient
000322 506a                      	subi	r, 10		; fix remainder
000323 cffb                      	rjmp	div10_1	; Continue until error is corrected
                                 
                                 div10_2:
000324 900f                      	pop	r0		; Restore registers
000325 9508                      	ret			; Return from function
                                 
                                 ;*********************************************************************
                                 ;*	Bitmap Font Information
                                 ;*	Adapted into assembly code by Justin Goins.
                                 ;*	You can edit characters or add symbols if you choose (by modifying the data below)
                                 ;*	Each character is represented as a 8 x 16 pattern of dots (8 dots wide and 16 dots high).
                                 ;*	This implies that 16 bytes are allocated to represent each character.
                                 ;*
                                 ;*	The character information is arranged so that each line below equates to a single character.
                                 ;*	The first line is ASCII character 0, the next line is ASCII character 1,
                                 ;*	the next line is ASCII character 2, and so on.
                                 ;*	You can assign characters to any index within the extended ASCII range (0 to 255).
                                 ;*	With a bit of experimentation it's possible to define and display emojis (or any other graphical output).
                                 ;*	Be creative and have fun!
                                 ;*
                                 ;*	From original license file:
                                 ;*	Copyright 2011 Suraj N. Kurapati <https://github.com/sunaku/tamzen-font>
                                 ;*	Tamzen font is free.  You are hereby granted permission to use, copy, modify, and distribute it as you see fit.
                                 ;*	Tamzen font is provided "as is" without any express or implied warranty.
                                 ;*********************************************************************

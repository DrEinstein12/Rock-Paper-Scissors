                                 ;* Target MCU        : ATmega32U4
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M32U4DEF_INC_
                                 #endif  /* _M32U4DEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;***********************************************************
                                 ;*  Internal Register Definitions and Constants
                                 ;*
                                 ;*  Note: r18 and r19 are reused across routines:
                                 ;*    r18 (choice) also acts as 'send' in USART_Send
                                 ;*                 and as inner loop counter in HALF_SECOND_WAIT
                                 ;*    r19 (opponent) also acts as 'receive' in USART ISR
                                 ;*                   and as outer loop counter in HALF_SECOND_WAIT
                                 ;***********************************************************
                                 .def    mpr = r16               ; Multi-Purpose Register: general scratch register
                                 .def    choice = r18            ; Player's RPS choice: 1=Rock, 2=Paper, 3=Scissors
                                 .def    opponent = r19          ; Opponent's RPS choice received over USART
                                 .def    waitcnt = r23           ; Wait Loop Counter
                                 .def    temp = r25              ; Temp register used in TIMER1_INT ISR
                                 
                                 .equ	But7 = 7				; Bit position of PD7 button (start/ready)
                                 .equ	But2 = 4				; Bit position of PD4 button (cycle choice)
                                 .equ	WTime = 150				; Time to wait in wait loop
                                 
                                 .equ	is_ready = 0			; Bit flag for ready state (reserved)
                                 
                                 ; RPS choice constants
                                 .equ	Rock     = 1
                                 .equ	Paper    = 2
                                 .equ	Scissors = 3
                                 
                                 ;***********************************************************
                                 ;*  Timer1 Preload Value = 0x48E5
                                 ;*  Prescaler = 256 => timer tick = 256/8MHz = 32 microseconds
                                 ;*  Ticks for 1.5s = 1.5 / 0.000032 = 46875
                                 ;*  Preload = 65536 - 46875 = 18661 = 0x48E5
                                 ;***********************************************************
                                 .equ PRELOAD_HIGH = 0x48        ; High byte of Timer1 preload value
                                 .equ PRELOAD_LOW  = 0xE5        ; Low byte of Timer1 preload value
                                 
                                 ; Handshake byte sent between boards to signal "I am ready to play"
                                 .equ    SendReady = 0b11111111
                                 
                                 
                                 ;***********************************************************
                                 ;*  Start of Code Segment
                                 ;***********************************************************
                                 .cseg                           ; Beginning of code segment
                                 
                                 ;***********************************************************
                                 ;*  Interrupt Vectors
                                 ;***********************************************************
                                 .org    $0000                   ; Reset vector
000000 c055                      	rjmp    INIT                ; Jump to initialization on reset
                                 
                                 .org	$0028                   ; Timer1 overflow interrupt vector
000028 d0ff                      	rcall TIMER1_INT            ; Call timer ISR to update LED countdown
000029 9518                      	reti
                                 
                                 .org    $0032                   ; USART1 RX complete interrupt vector
000032 c088                          rjmp    USART_Receive_Interrupt   ; Jump to ISR when a byte is received
                                 
                                 .org    $0056                   ; End of Interrupt Vectors
                                 
                                 
                                 ;***********************************************************
                                 ;*  Program Initialization
                                 ;***********************************************************
                                 INIT:
                                 	; --- Stack Pointer ---
                                 	; Must be set before any rcall, push, or pop
000056 ef0f                      	ldi		mpr, low(RAMEND)    ; Load low byte of top of SRAM
000057 bf0d                      	out		SPL, mpr            ; Set stack pointer low byte
000058 e00a                      	ldi		mpr, high(RAMEND)   ; Load high byte of top of SRAM
000059 bf0e                      	out		SPH, mpr            ; Set stack pointer high byte
                                 
                                 	; --- Port B: Output (LEDs on PB7:PB4) ---
00005a ef0f                      	ldi		mpr, $FF            ; All pins = output
00005b b904                      	out		DDRB, mpr
00005c e000                      	ldi		mpr, $00            ; All LEDs off initially
00005d b905                      	out		PORTB, mpr
                                 
                                 	; --- Port D: Input (Buttons on PD7 and PD4) ---
00005e e000                      	ldi		mpr, $00            ; All pins = input
00005f b90a                      	out		DDRD, mpr
000060 ef0f                      	ldi		mpr, $FF            ; Enable pull-ups on all Port D pins
000061 b90b                      	out		PORTD, mpr
                                 
                                 	; --- USART1: 2400 baud, double-speed mode ---
000062 e002                      	ldi		mpr, (1 << U2X1)    ; U2X1=1 enables double-speed (halves baud divider)
000063 9300 00c8                 	sts		UCSR1A, mpr
                                 
000065 e000                      	ldi     mpr, high(207)
000066 9300 00cd                 	sts     UBRR1H, mpr
000068 ec0f                      	ldi		mpr, low(207)
000069 9300 00cc                 	sts		UBRR1L, mpr
                                 	; Enable RX, TX, and RX complete interrupt
00006b e908                      	ldi     mpr, (1 << RXEN1) | (1 << TXEN1) | (1 << RXCIE1)
00006c 9300 00c9                 	sts     UCSR1B, mpr
                                 	; Frame format: 8 data bits, 2 stop bits
00006e e00e                      	ldi     mpr, (1 << UCSZ11) | (1 << UCSZ10) | (1 << USBS1)
00006f 9300 00ca                 	sts     UCSR1C, mpr
                                 
                                 	; --- Timer1: Normal mode, Prescaler = 256 ---
000071 e000                      	ldi		mpr, 0x00           ; WGM bits = 0 => Normal mode (counts up, overflows at 0xFFFF)
000072 9300 0080                 	sts		TCCR1A, mpr
000074 e004                      	ldi		mpr, (1 << CS12)    ; CS12=1, CS11=0, CS10=0 => prescaler = 256
000075 9300 0081                 	sts		TCCR1B, mpr
000077 e408                      	ldi     mpr, PRELOAD_HIGH   ; Preload timer so it overflows after 1.5s
000078 9300 0085                 	sts     TCNT1H, mpr
00007a ee05                      	ldi     mpr, PRELOAD_LOW
00007b 9300 0084                 	sts     TCNT1L, mpr
00007d e001                      	ldi     mpr, (1 << TOIE1)   ; Enable Timer1 overflow interrupt
00007e 9300 006f                 	sts     TIMSK1, mpr
000080 9478                      	sei                         ; Enable global interrupts
                                 
                                 	; --- LCD Initialization ---
000081 d188                      	rcall LCDInit
                                 
                                 	; --- Display Welcome screen ---
                                 	; Copy 32 bytes (2 lines x 16 chars) from flash into Line1 buffer
000082 e5e4                      	ldi     ZL, low(Welcome_START << 1)  ; << 1 converts word address to byte address
000083 e0f3                      	ldi     ZH, high(Welcome_START << 1)
000084 e0b1                      	ldi     XH, high(Line1)
000085 e0a0                      	ldi     XL, low(Line1)
000086 e210                      	ldi     r17, 32             ; 32 bytes = both LCD lines
000087 d008                      	rcall   LOAD_STRING         ; Copy flash string into SRAM buffer
000088 e021                      	ldi     choice, 1           ; Default choice: Rock
000089 e033                      	ldi     opponent, 3         ; Initial test value
00008a d1a5                      	rcall   LCDWrite            ; Render SRAM buffer to LCD
                                 
                                 
                                 ;***********************************************************
                                 ;*  Main Program
                                 ;***********************************************************
                                 MAIN:
00008b e023                      	ldi     choice, 3           ; Reset choice to Rock at top of each loop
00008c b109                      	in		mpr, PIND           ; Read Port D button state
00008d ff07                      	sbrs	mpr, BUT7           ; Skip next if PD7 = 1 (not pressed)
00008e c037                      	rjmp	STANDBY             ; PD7 pressed (low) => go to standby/ready state
00008f cffb                      	rjmp	MAIN                ; Not pressed => keep polling
                                 
                                 
                                 ;***********************************************************
                                 ;*  LOAD_STRING
                                 ;*  Copies a string from program flash into SRAM.
                                 ;***********************************************************
                                 LOAD_STRING:
000090 92ff                      	push    r15                 ; Save r15 (used as byte transfer buffer)
000091 931f                      	push    r17                 ; Save r17 (loop counter, restored for caller)
                                 LS_LOOP:
000092 90f5                      	lpm     r15, Z+             ; Load 1 byte from flash at Z, then Z++
000093 92fd                      	st      X+, r15             ; Store byte to SRAM at X, then X++
000094 951a                      	dec     r17                 ; Decrement remaining byte count
000095 f7e1                      	brne    LS_LOOP             ; Loop until all bytes copied
000096 911f                      	pop     r17                 ; Restore loop counter
000097 90ff                      	pop     r15                 ; Restore r15
000098 9508                      	ret
                                 
                                 
                                 ;***********************************************************
                                 ;*  Functions and Subroutines
                                 ;***********************************************************
                                 
                                 ;----------------------------------------------------------------
                                 ; Sub:	HALF_SECOND_WAIT
                                 ; Desc:	Software busy-wait of ~500ms used for button debouncing.
                                 ;       r18 and r19 are temporarily used as loop counters.
                                 ;       Their values (choice and opponent) are saved/restored
                                 ;       via push/pop so callers are unaffected.
                                 ;
                                 ;       Cycle count formula:
                                 ;       (((((3*r18)-1+4)*r19)-1+4)*waitcnt)-1+16
                                 ;----------------------------------------------------------------
                                 HALF_SECOND_WAIT:
000099 937f                      	push    waitcnt             ; Save waitcnt
00009a 933f                      	push    r19                 ; Save opponent (r19 reused as outer loop counter)
00009b 932f                      	push    r18                 ; Save choice (r18 reused as inner loop counter)
                                 
00009c e674                      	ldi		waitcnt, 100            ; 100 outer iterations
                                 HWAIT_OUTER:
00009d e238                      	ldi		r19, 40                 ; 40 middle iterations per outer loop
                                 HWAIT_LOOP:
00009e ec28                      	ldi		r18, 200                ; 200 inner iterations per middle loop
                                 HWAIT_INNER:
00009f 952a                      	dec		r18                     ; Decrement inner counter
0000a0 f7f1                      	brne	HWAIT_INNER            ; Loop until inner = 0
0000a1 953a                      	dec		r19                     ; Decrement middle counter
0000a2 f7d9                      	brne	HWAIT_LOOP             ; Loop until middle = 0
0000a3 957a                      	dec		waitcnt                 ; Decrement outer counter
0000a4 f7c1                      	brne	HWAIT_OUTER            ; Loop until outer = 0
                                 
0000a5 912f                      	pop     r18                 ; Restore choice
0000a6 913f                      	pop     r19                 ; Restore opponent
0000a7 917f                      	pop     waitcnt             ; Restore waitcnt
0000a8 9508                      	ret
                                 
                                 
                                 ;***********************************************************
                                 ;*  USART Communication
                                 ;***********************************************************
                                 USART_Send:
0000a9 9100 00c8                 	lds		mpr, UCSR1A
0000ab ff05                      	sbrs	mpr, UDRE1              ; Skip next if transmit buffer empty
0000ac cffc                      	rjmp	USART_Send              ; Not empty yet, keep waiting
0000ad 9320 00ce                 	sts		UDR1, r18               ; Write byte to USART data register (r18 = choice = send)
                                 WAIT_TX:
0000af 9100 00c8                 	lds		mpr, UCSR1A
0000b1 ff06                      	sbrs	mpr, TXC1               ; Skip next if transmission complete
0000b2 cffc                      	rjmp	WAIT_TX                 ; Not done yet, keep waiting
0000b3 9508                      	ret
                                 
                                 USART_Receive:
0000b4 9100 00c8                 	lds		mpr, UCSR1A
0000b6 ff07                      	sbrs	mpr, RXC1               ; Skip next if receive complete flag set
0000b7 cffc                      	rjmp	USART_Receive           ; Not received yet, keep waiting
0000b8 9130 00ce                 	lds		opponent, UDR1          ; Read received byte into opponent register
0000ba 9508                      	ret
                                 
                                 USART_Receive_Interrupt:
0000bb 930f                      	push	mpr
0000bc b70f                      	in		mpr, SREG
0000bd 930f                      	push	mpr
                                 
0000be 9100 00ce                 	lds		mpr, UDR1
0000c0 9300 0120                 	sts		OpponentByte, mpr
                                 
0000c2 910f                      	pop		mpr
0000c3 bf0f                      	out		SREG, mpr
0000c4 910f                      	pop		mpr
0000c5 9518                      	reti
                                 
                                 ;-----------------------------------------------------------
                                 ; STANDBY
                                 ; Displays "Ready, Waiting / For the Opponent" on the LCD,
                                 ; sends the SendReady handshake byte to the opponent,
                                 ; then spins until the opponent also sends SendReady.
                                 ;-----------------------------------------------------------
                                 STANDBY:
0000c6 e000                      	ldi		mpr, 0
0000c7 9300 0120                 	sts		OpponentByte, mpr
                                 	; Load and display the standby message (32 bytes = 2 LCD lines)
0000c9 e7e4                      	ldi     ZL, low(Standby_START << 1)
0000ca e0f3                      	ldi     ZH, high(Standby_START << 1)
0000cb e0b1                      	ldi     XH, high(Line1)
0000cc e0a0                      	ldi     XL, low(Line1)
0000cd e210                      	ldi     r17, 32             ; Two full lines
0000ce dfc1                      	rcall   LOAD_STRING
0000cf d160                      	rcall   LCDWrite
                                 
                                 STANDBY_LOOP:
                                     ; send ready byte
0000d0 932f                          push r18
0000d1 ef2f                          ldi  r18, SendReady
0000d2 dfd6                          rcall USART_Send
0000d3 912f                          pop  r18
                                 
                                     ; check if opponent sent ready
0000d4 9100 0120                     lds  mpr, OpponentByte
0000d6 3f0f                          cpi  mpr, SendReady
0000d7 f7c1                          brne STANDBY_LOOP
                                 
0000d8 c000                          rjmp START
                                 
                                 ;-----------------------------------------------------------
                                 ; START
                                 ; Displays "Game Start!" and fires the 1.5s LED countdown.
                                 ; Then enters CHOICE_LOOP where the player cycles their pick.
                                 ;-----------------------------------------------------------
                                 START:
                                 	; Line1: "Game Start!"
0000d9 e9e4                      	ldi     ZL, low(Game_Start << 1)
0000da e0f3                      	ldi     ZH, high(Game_Start << 1)
0000db e0b1                      	ldi     XH, high(Line1)
0000dc e0a0                      	ldi     XL, low(Line1)
0000dd e110                      	ldi     r17, 16
0000de dfb1                      	rcall   LOAD_STRING
                                 
                                 	; Line2: blank
0000df e0e4                      	ldi     ZL, low(Blank_Line_Start << 1)
0000e0 e0f4                      	ldi     ZH, high(Blank_Line_Start << 1)
0000e1 e0b1                      	ldi     XH, high(Line2)
0000e2 e1a0                      	ldi     XL, low(Line2)
0000e3 e110                      	ldi     r17, 16
0000e4 dfab                      	rcall   LOAD_STRING
                                 
0000e5 d14a                      	rcall	LCDWrite
0000e6 d02d                      	rcall   START_TIMER         ; Light all 4 LEDs and begin 1.5s countdown
                                 
                                 CHOICE_LOOP:
0000e7 b109                      	in		mpr, PIND           ; Read Port D button state
0000e8 ff04                      	sbrs	mpr, But2           ; Skip next if PD4 = 1 (not pressed)
0000e9 c001                      	rjmp	BUTTON_PRESSED      ; PD4 low (pressed) => update and display choice
0000ea c006                      	rjmp	AFTER_CHOICE        ; Not pressed => just check the timer
                                 
                                 BUTTON_PRESSED:
                                 	; Only update and redisplay when button was actually pressed	
0000eb 3023                      	cpi		choice, 3
0000ec f049                      	breq	DISPLAY_ROCK
0000ed 3021                      	cpi		choice, 1
0000ee f089                      	breq	DISPLAY_PAPER
0000ef 3022                      	cpi		choice, 2
0000f0 f0c9                      	breq	DISPLAY_SCISSORS
                                 
                                 AFTER_CHOICE:
                                 	; Read PORTB (output register) 
0000f1 b105                      	in		mpr, PORTB          ; Read current LED output state
0000f2 7f00                      	andi	mpr, $F0            ; Isolate upper nibble (LED bits PB7:PB4)
0000f3 fd04                      	sbrc	mpr, 4              ; Skip next if bit 4 is clear
0000f4 cff2                      	rjmp	CHOICE_LOOP         ; Bit 4 set => at least one LED on => keep looping
0000f5 c050                      	rjmp	USE_CHOICE          ; All LEDs off => timer expired => lock in choice
                                 
                                 ;-----------------------------------------------------------
                                 ; DISPLAY_ROCK / DISPLAY_PAPER / DISPLAY_SCISSORS
                                 ; Show the player's current choice on Line2 of the LCD,
                                 ; wait 500ms to debounce, then return to AFTER_CHOICE.
                                 ;-----------------------------------------------------------
                                 DISPLAY_ROCK:
0000f6 e021                      	ldi		choice, 1           ; pre increment so opponent display displays the correct choice.
0000f7 eae4                      	ldi     ZL, low(Rock_Start << 1)
0000f8 e0f3                      	ldi     ZH, high(Rock_Start << 1)
0000f9 e0b1                      	ldi     XH, high(Line2)     ; Write to bottom LCD line
0000fa e1a0                      	ldi     XL, low(Line2)
0000fb e110                      	ldi     r17, 16
0000fc df93                      	rcall   LOAD_STRING
0000fd d132                      	rcall   LCDWrite
0000fe df9a                      	rcall   HALF_SECOND_WAIT    ; Debounce delay
                                 
0000ff cff1                      	rjmp    AFTER_CHOICE
                                 
                                 DISPLAY_PAPER:
000100 9523                      	inc		choice
000101 ebe4                      	ldi     ZL, low(Paper_Start << 1)
000102 e0f3                      	ldi     ZH, high(Paper_Start << 1)
000103 e0b1                      	ldi     XH, high(Line2)
000104 e1a0                      	ldi     XL, low(Line2)
000105 e110                      	ldi     r17, 16
000106 df89                      	rcall   LOAD_STRING
000107 d128                      	rcall   LCDWrite
000108 df90                      	rcall   HALF_SECOND_WAIT
                                 
000109 cfe7                      	rjmp    AFTER_CHOICE
                                 
                                 DISPLAY_SCISSORS:
00010a 9523                      	inc		choice
00010b ece4                      	ldi     ZL, low(Scissors_Start << 1)
00010c e0f3                      	ldi     ZH, high(Scissors_Start << 1)
00010d e0b1                      	ldi     XH, high(Line2)
00010e e1a0                      	ldi     XL, low(Line2)
00010f e110                      	ldi     r17, 16
000110 df7f                      	rcall   LOAD_STRING
000111 d11e                      	rcall   LCDWrite
000112 df86                      	rcall   HALF_SECOND_WAIT
                                 
000113 cfdd                      	rjmp    AFTER_CHOICE
                                 
                                 ;-----------------------------------------------------------
                                 ; START_TIMER
                                 ; Reloads Timer1 with the preload value, enables the
                                 ; overflow interrupt, starts the clock, and turns on
                                 ; all 4 LEDs (PB7:PB4) to begin the visual countdown.
                                 ;-----------------------------------------------------------
                                 START_TIMER:
000114 930f                      	push	mpr
000115 e074                      	ldi     waitcnt, 4          ; 4 LEDs = 4 countdown steps
                                 
                                 	; Reload Timer1 so it overflows after exactly 1.5s
000116 e408                      	ldi     mpr, PRELOAD_HIGH
000117 9300 0085                 	sts     TCNT1H, mpr
000119 ee05                      	ldi     mpr, PRELOAD_LOW
00011a 9300 0084                 	sts     TCNT1L, mpr
                                 
00011c e001                      	ldi     mpr, (1 << TOIE1)   ; Enable Timer1 overflow interrupt
00011d 9300 006f                 	sts     TIMSK1, mpr
                                 
00011f e004                      	ldi		mpr, (1 << CS12)    ; Start Timer1 with prescaler = 256
000120 9300 0081                 	sts		TCCR1B, mpr
                                 
                                 	; Turn on all 4 LEDs (PB7:PB4), preserve lower nibble (PB3:PB0)
000122 b105                      	in		mpr, PORTB
000123 700f                      	andi	mpr, $0F            ; Clear upper nibble
000124 6f00                      	ori		mpr, $F0            ; Set all 4 LED bits high
000125 b905                      	out		PORTB, mpr
                                 
000126 910f                      	pop		mpr
000127 9508                      	ret
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; TIMER1_INT (Timer1 Overflow ISR)
                                 ; Called every 1.5s by Timer1 overflow.
                                 ; Shifts the LED pattern right by one (turns off one LED).
                                 ; When all LEDs are off, stops the timer entirely.
                                 ;-----------------------------------------------------------
                                 TIMER1_INT:
000128 930f                      	push    mpr
000129 939f                      	push    temp
                                 
                                 	; Read LEDs, shift right to turn off the highest lit LED
00012a b105                      	in      mpr, PORTB              ; Read current PORTB output state
00012b 7f00                      	andi    mpr, 0xF0               ; Isolate upper nibble (LED bits PB7:PB4)
00012c 2f90                      	mov     temp, mpr               ; Copy LED bits to temp
00012d 9596                      	lsr     temp                    ; Shift right => turns off one LED
00012e 7f90                      	andi    temp, 0xF0              ; Clear any bit that shifted into lower nibble
                                 
                                 	; Merge new LED state back with unchanged lower nibble
00012f b105                      	in      mpr, PORTB              ; Re-read PORTB to get PB3:PB0
000130 700f                      	andi    mpr, 0x0F               ; Keep only lower nibble
000131 2b09                      	or      mpr, temp               ; Combine with shifted LED bits
000132 b905                      	out     PORTB, mpr              ; Write updated state back to PORTB
                                 
                                 	; Check if all LEDs are now off (upper nibble = 0x00)
000133 7f00                      	andi	mpr, $F0
000134 3000                      	cpi		mpr, 0
000135 f439                      	brne    TIMER_CONTINUE          ; LEDs still on => keep timer running
                                 
                                 	; All LEDs off: disable timer completely
000136 e000                      	ldi     mpr, 0x00
000137 9300 006f                 	sts     TIMSK1, mpr             ; Disable Timer1 overflow interrupt
000139 e000                      	ldi     mpr, 0x00
00013a 9300 0081                 	sts     TCCR1B, mpr             ; Stop Timer1 clock (remove prescaler)
00013c c006                      	rjmp    END_TIMER
                                 
                                 TIMER_CONTINUE:
                                 	; Reload preload so next overflow also takes 1.5s
00013d e408                      	ldi     mpr, PRELOAD_HIGH
00013e 9300 0085                 	sts     TCNT1H, mpr
000140 ee05                      	ldi     mpr, PRELOAD_LOW
000141 9300 0084                 	sts     TCNT1L, mpr
                                 
                                 END_TIMER:
000143 919f                      	pop     temp
000144 910f                      	pop     mpr
000145 9508                      	ret                             ; Caller (interrupt vector) does reti
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; USE_CHOICE
                                 ; Sends the player's locked-in choice to the opponent,
                                 ; starts the suspense countdown, then waits for the
                                 ; opponent's choice to arrive via the USART ISR.
                                 ;-----------------------------------------------------------
                                 USE_CHOICE:
000146 df62                      	rcall USART_Send            ; Transmit choice (r18) to opponent
                                 
                                 GET_OPPONENT:
000147 dfcc                      	rcall START_TIMER           ; Start LED countdown while waiting
                                 
                                 RECEIVE_LOOP:
                                 	; Spin until opponent register holds a valid choice (1, 2, or 3)
                                 	; opponent is updated by USART_Receive_Interrupt ISR
000148 9130 0120                 	lds		opponent, OpponentByte
00014a 3031                      	cpi		opponent, 1
00014b f071                      	breq	DISPLAY_OPP_ROCK
00014c 9130 0120                 	lds		opponent, OpponentByte
00014e 3032                      	cpi		opponent, 2
00014f f071                      	breq	DISPLAY_OPP_PAPER
000150 9130 0120                 	lds		opponent, OpponentByte
000152 3033                      	cpi		opponent, 3
000153 f071                      	breq	DISPLAY_OPP_SCISSORS
000154 cff3                      	rjmp    RECEIVE_LOOP        ; Not valid yet => keep polling
                                 
                                 GameTIMER_LOOP:
                                 	; Wait here until the suspense timer expires
000155 b103                      	in		mpr, PINB
000156 7f00                      	andi	mpr, $F0            ; Check LED bits
000157 fd04                      	sbrc	mpr, 4              ; If bit 4 clear, timer has finished
000158 cffc                      	rjmp	GameTIMER_LOOP       ; Still running => wait
000159 c012                      	rjmp    GAME_LOGIC          ; Timer done => evaluate the result
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; Show the opponent's choice on Line1 while in GameTIMER_LOOP.
                                 ;-----------------------------------------------------------
                                 DISPLAY_OPP_ROCK:
00015a eae4                      	ldi		ZL, low(Rock_Start << 1)
00015b e0f3                      	ldi		ZH, high(Rock_Start << 1)
00015c d009                      	rcall	UPDATE_OPP_LCD      ; Call a shared update routine
00015d cff7                      	rjmp	GameTIMER_LOOP      ; Go wait for the timer to finish
                                 
                                 DISPLAY_OPP_PAPER:
00015e ebe4                      	ldi		ZL, low(Paper_Start << 1)
00015f e0f3                      	ldi		ZH, high(Paper_Start << 1)
000160 d005                      	rcall	UPDATE_OPP_LCD
000161 cff3                      	rjmp	GameTIMER_LOOP
                                 
                                 DISPLAY_OPP_SCISSORS:
000162 ece4                      	ldi		ZL, low(Scissors_Start << 1)
000163 e0f3                      	ldi		ZH, high(Scissors_Start << 1)
000164 d001                      	rcall	UPDATE_OPP_LCD
000165 cfef                      	rjmp	GameTIMER_LOOP
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; UPDATE_OPP_LCD
                                 ; Helper to avoid repeating the same 6 lines of code
                                 ;-----------------------------------------------------------
                                 UPDATE_OPP_LCD:
000166 e0b1                      	ldi		XH, high(Line1)
000167 e0a0                      	ldi		XL, low(Line1)
000168 e110                      	ldi		r17, 16
000169 df26                      	rcall	LOAD_STRING
00016a d0c5                      	rcall	LCDWrite
00016b 9508                      	ret                         
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; GAME_LOGIC
                                 ; Determines win/lose/tie using modular arithmetic:
                                 ;   diff = (choice - opponent) mod 3
                                 ;   diff == 0 => Tie
                                 ;   diff == 1 => Win  (e.g. Rock beats Scissors)
                                 ;   diff == 2 => Lose (e.g. Rock loses to Paper)
                                 ;-----------------------------------------------------------
                                 GAME_LOGIC:	
00016c 1b23                      	sub		choice, opponent       ; diff = choice - opponent
00016d f412                      	brpl	MODULO                 ; If result >= 0, skip the wrap
00016e e033                      	ldi		opponent, 3
00016f 0f23                      	add		choice, opponent       ; Negative result => add 3 to wrap into 0..2
                                 
                                 MODULO:
000170 3021                      	cpi		choice, 1
000171 f081                      	breq	DISPLAY_WIN            ; diff == 1 => player wins
000172 3022                      	cpi		choice, 2
000173 f0d9                      	breq	DISPLAY_LOSE           ; diff == 2 => player loses
000174 c000                      	rjmp	DISPLAY_TIE            ; diff == 0 => tie
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; DISPLAY_TIE / DISPLAY_WIN / DISPLAY_LOSE
                                 ; Start the LED timer, loop displaying the result on Line1
                                 ; until the timer expires, then restart the game.
                                 ;-----------------------------------------------------------
                                 DISPLAY_TIE:
000175 df9e                      	rcall	START_TIMER           ; Start LED countdown
                                 TIE_LOOP:
000176 efe4                      	ldi     ZL, low(Draw_Start << 1)
000177 e0f3                      	ldi     ZH, high(Draw_Start << 1)
000178 e0b1                      	ldi     XH, high(Line1)
000179 e0a0                      	ldi     XL, low(Line1)
00017a e110                      	ldi     r17, 16
00017b df14                      	rcall   LOAD_STRING
00017c d0b3                      	rcall   LCDWrite
00017d b103                      	in		mpr, PINB
00017e 7f00                      	andi	mpr, $F0            ; Check if LEDs are still on
00017f fd04                      	sbrc	mpr, 4              ; If bit 4 clear, timer done
000180 cff5                      	rjmp    TIE_LOOP
000181 c01a                      	rjmp    RESTART_GAME
                                 
                                 
                                 DISPLAY_WIN:
000182 df91                      	rcall	START_TIMER
                                 WIN_LOOP:
000183 ede4                      	ldi     ZL, low(Win_Start << 1)
000184 e0f3                      	ldi     ZH, high(Win_Start << 1)
000185 e0b1                      	ldi     XH, high(Line1)
000186 e0a0                      	ldi     XL, low(Line1)
000187 e110                      	ldi     r17, 16
000188 df07                      	rcall   LOAD_STRING
000189 d0a6                      	rcall   LCDWrite
00018a b103                      	in		mpr, PINB
00018b 7f00                      	andi	mpr, $F0
00018c fd04                      	sbrc	mpr, 4              ; If bit 4 clear, timer done
00018d cff5                      	rjmp    WIN_LOOP
00018e c00d                      	rjmp    RESTART_GAME
                                 
                                 
                                 DISPLAY_LOSE:
00018f df84                      	rcall	START_TIMER
                                 LOSE_LOOP:
000190 eee4                      	ldi     ZL, low(Lose_Start << 1)
000191 e0f3                      	ldi     ZH, high(Lose_Start << 1)
000192 e0b1                      	ldi     XH, high(Line1)
000193 e0a0                      	ldi     XL, low(Line1)
000194 e110                      	ldi     r17, 16
000195 defa                      	rcall   LOAD_STRING
000196 d099                      	rcall   LCDWrite
000197 b103                      	in		mpr, PINB
000198 7f00                      	andi	mpr, $F0
000199 fd04                      	sbrc	mpr, 4              ; If bit 4 clear, timer done
00019a cff5                      	rjmp    LOSE_LOOP
00019b c000                      	rjmp    RESTART_GAME
                                 
                                 
                                 ;-----------------------------------------------------------
                                 ; RESTART_GAME
                                 ; Resets choice, opponent, waitcnt, and LEDs back to
                                 ; their initial state, reloads the welcome screen,
                                 ; then jumps back to MAIN.
                                 ;-----------------------------------------------------------
                                 RESTART_GAME:
00019c e021                      	ldi     choice, 1           ; Reset player choice to Rock
00019d e031                      	ldi     opponent, 1         ; Reset opponent choice
00019e 2777                      	clr     waitcnt             ; Clear timer countdown counter
00019f e000                      	ldi     mpr, 0x00
0001a0 b905                      	out     PORTB, mpr          ; Turn off all LEDs
                                 
                                 	; Reload and display the welcome message
0001a1 e5e4                      	ldi     ZL, low(Welcome_START << 1)
0001a2 e0f3                      	ldi     ZH, high(Welcome_START << 1)
0001a3 e0b1                      	ldi     XH, high(Line1)
0001a4 e0a0                      	ldi     XL, low(Line1)
0001a5 e210                      	ldi     r17, 32             ; Two lines
0001a6 dee9                      	rcall   LOAD_STRING
0001a7 d088                      	rcall   LCDWrite
                                 
0001a8 940c 008b                 	jmp     MAIN                ; Return to main polling loop
                                 
                                 
